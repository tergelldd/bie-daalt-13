generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShortUrl {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  longUrl     String
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
}